      "delete": {
        "tags": [
          "proxy_clusters"
        ],
        "summary": "Cluster redirect",
        "description": "Redirect to the cluster if exists.",
        "operationId": "delete_redirect",
        "parameters": [
          {
            "name": "ns",
            "in": "path",
            "description": "Namespace containing the cluster.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "cluster",
            "in": "path",
            "description": "Cluster name, must match an enabled cluster in the namespace.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "path",
            "in": "path",
            "description": "Corresponding path to resource given to the kube api server.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Response from remote cluster."
          },
          "404": {
            "description": "Cluster not found or disabled."
          },
          "500": {
            "description": "Internal server error."
          }
        }
      },
      "patch": {
        "tags": [
          "proxy_clusters"
        ],
        "summary": "Cluster redirect",
        "description": "Redirect to the cluster if exists.",
        "operationId": "patch_redirect",
        "parameters": [
          {
            "name": "ns",
            "in": "path",
